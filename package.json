{
  "name": "css-class-finder",
  "displayName": "CSS Class Finder",
  "description": "Easily transfer HTML classes to CSS without risk of typos or missed classes.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
      "command": "css-class-finder.transferSelectedClasses",
      "title": "CSS Class Finder: Transfer Selected Classes"
      },
      {
      "command": "css-class-finder.autoSuggestClasses",
      "title": "CSS Class Finder: Automatically Suggest Classes"
      },
      {
      "command": "css-class-finder.autoTransferClasses",
      "title": "CSS Class Finder: Automatically Transfer Classes"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
